# -- Hardware Scalability Config --
# OSMNX_RADIUS_METERS: Map download radius in meters.
#   3000  = ~2k nodes, safe for 8 GB RAM
#   10000 = ~15k nodes, needs 16 GB+
#   25000 = full city, needs 32 GB+
OSMNX_RADIUS_METERS=3000

# OSMNX_CENTER_LAT / LON: Center point for map download.
#   Default: HITEC City, Hyderabad
OSMNX_CENTER_LAT=17.4435
OSMNX_CENTER_LON=78.3772

# MAX_TRAINING_EPISODES: Q-Learning training cap.
#   500  = ~2 min on i5 (safe default)
#   5000 = ~20 min, better convergence
#   50000 = cloud-scale, full convergence
MAX_TRAINING_EPISODES=500